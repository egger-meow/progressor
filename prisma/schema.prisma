// Prisma schema for Progressor. See docs/domain-model.md for the canonical
// concept definitions these models implement, and docs/system-direction.md
// for the layering rule (only src/server/ may import from @prisma/client).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// TrackableItem implements docs/domain-model.md's "Trackable Item" (Book /
// Course). `type` and `status` are plain strings, not Prisma enums, because
// the sqlite connector has no native enum support — validity is enforced in
// src/server/trackable-items.ts instead.
model TrackableItem {
  id             String   @id @default(cuid())
  title          String
  type           String
  priority       Int
  status         String   @default("not-started")
  unitCount      Int
  unitsCompleted Int      @default(0)
  estimatedDays  Int
  // Optional explicit target completion date — deliberately separate from
  // estimatedDays (never auto-derived from it, never auto-frozen): most
  // useful set directly on a not-yet-started item where "today + N days"
  // doesn't mean anything yet. Not consumed by the Scheduler yet.
  targetDate     DateTime?
  // "Chapters average Nx longer than normal" — the BASELINE multiplier
  // applied to any unit without its own entry in unitWeightOverrides below.
  // Consumed by advanceTrackableItemProgress (how many sittings before
  // unitsCompleted rolls forward), the Weekly View's progress fraction,
  // and the Scheduler's horizon engine (how many sessions to place before
  // an item is considered "done" scheduling).
  unitWeightMultiplier Float @default(1.0)
  // JSON-encoded object mapping a specific unit index (1-based, "第 N 章"
  // numbering) to its own multiplier — overrides unitWeightMultiplier for
  // that one unit only, e.g. {"8":2.5} means chapter 8 alone takes 2.5x
  // the baseline. Project owner, 2026-07-23: a flat per-item average
  // doesn't fit "usually 3 days/chapter, but chapter 8 is unusually long
  // so give it 2.5x (~7 days) while every other chapter stays at the
  // baseline" — most chapters need no entry here at all. Parsed/validated
  // in src/server/trackable-items.ts.
  unitWeightOverrides String @default("{}")
  // How many of this unit's sittings have been confirmed done so far
  // (via the daily check-in gate's 是/已完成 answer, or the Weekly View's
  // 完成本次 button — src/server/trackable-items.ts's
  // advanceTrackableItemProgress). Rolls unitsCompleted forward by one
  // once it reaches round(unitWeightMultiplier), then resets to 0. Reset
  // to 0 by any manual edit of unitsCompleted too (see updateTrackableItem)
  // since a manual override invalidates whatever partial count was mid-way.
  currentUnitSessionsCompleted Int @default(0)
  // JSON-encoded string array (same convention as Routine.anchor below) —
  // free-text labels the user assigns, e.g. a course tagged "學校課" or a
  // book tagged "trader". Parsed/validated in src/server/tags.ts.
  tags           String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([type, status])
}

// WipLimit implements docs/domain-model.md's "WIP Limit": one configured
// maxInProgress per TrackableItem `type`, enforced independently per type.
model WipLimit {
  type          String @id
  maxInProgress Int
}

// One row per TrackableItemType ("book"/"course", same one-row-per-type
// shape as WipLimit above) — an opt-in recurring reservation for that
// category, mirroring Routine's cadence/anchor/timeOfDayPreference/
// preferredStartTime/durationMinutes vocabulary (validated via the shared
// src/server/cadence.ts, since this is the same shape/algorithm as Routine,
// unlike FixedCommitment/DeadlineTask which are deliberately kept separate).
// A type with no row here falls back to today's priority-ordered flexible
// placement (src/scheduler/flexible-placement.ts) unchanged — this is
// additive, never a breaking replacement. Placement:
// src/scheduler/category-placement.ts.
model CategoryItemSchedule {
  type                 String   @id
  cadence              String
  anchor               String?
  // JSON-encoded array of TimeOfDayPreference — see Routine's field below
  // for why this is a non-nullable array, not a nullable single string.
  timeOfDayPreferences String   @default("[]")
  preferredStartTime   String?
  durationMinutes      Int      @default(120)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// Routine implements docs/domain-model.md's "Routine". `cadence` is a
// plain string for the same reason as TrackableItem's `type`/`status` (no
// sqlite enum support). `anchor`'s shape depends on `cadence` (weekday(s)
// for weekly, day(s)-of-month for monthly, unused for daily), so it's
// stored as a JSON-encoded array of integers and validated in
// src/server/routines.ts rather than as columns. `timeOfDayPreferences` is
// a JSON-encoded array of the same four buckets (multi-select, 2026-07-22
// — was a single nullable string; the Scheduler now merges adjacent
// selected buckets into one continuous search window, and tries
// non-adjacent selections in order — see
// src/scheduler/occurrence-timing.ts). `preferredStartTime` ("HH:mm", 24h)
// is the domain-model doc's Time-of-Day Preference "(or an explicit hour
// range)" case: an optional concrete anchor the Scheduler tries before
// `timeOfDayPreferences`. `durationMinutes` (default 120) replaces what
// used to be a single hardcoded `SESSION_DURATION_MS` the Scheduler
// applied to every Routine occurrence — the default matches that prior
// constant exactly, so an existing Routine's placement is unaffected until
// its duration is edited.
model Routine {
  id                   String   @id @default(cuid())
  title                String
  category             String
  cadence              String
  anchor               String?
  timeOfDayPreferences String   @default("[]")
  preferredStartTime   String?
  durationMinutes      Int      @default(120)
  // JSON-encoded string array — see TrackableItem.tags above.
  tags                 String   @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// FixedCommitment and DeadlineTask both implement docs/domain-model.md's
// "Semester Commitment" umbrella — deliberately two separate models, not
// one polymorphic table, because the two kinds are semantically
// incompatible (hard constraint vs. flexible-before-a-deadline) and must
// stay non-interchangeable in code, per that doc's Naming Conventions
// section (the same rule that keeps Routine and Fixed Commitment apart).
// `ignoreSemesterBounds` (default false): when a `Semester` is
// configured, a Fixed Commitment is only placed for weeks inside its
// [start week, start week + weekCount) range unless this is true (e.g.
// a standing meeting with a professor that isn't semester-bound). See
// `Semester` below and src/scheduler/hard-constraints.ts.
model FixedCommitment {
  id                   String   @id @default(cuid())
  title                String
  dayOfWeek            Int
  startTime            String
  endTime              String
  ignoreSemesterBounds Boolean  @default(false)
  // JSON-encoded string array — see TrackableItem.tags above.
  tags                 String   @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model DeadlineTask {
  id             String   @id @default(cuid())
  title          String
  dueAt          DateTime
  // Total estimated work, in hours — the Scheduler splits this budget
  // across one or more sessions in the week's free slack before dueAt
  // (src/scheduler/hard-constraints.ts's placeDeadlineTasks), rather than
  // placing a single fixed-length session per task.
  estimatedHours Float
  // JSON-encoded string array — see TrackableItem.tags above.
  tags           String   @default("[]")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// Singleton (fixed id — this is a single-user app, one active semester
// at a time): a configurable start date + week count (default 16) that
// bounds a non-opted-out FixedCommitment's occurrences, and drives the
// Weekly View's "第 N 週" display. Not part of docs/domain-model.md's
// original concept list — added 2026-07-21 for `Semester`-scoped Fixed
// Commitments; see that doc's "Semester Commitment" section for the
// terminology this extends.
model Semester {
  id        String   @id @default("singleton")
  startDate DateTime
  weekCount Int      @default(16)
  updatedAt DateTime @updatedAt
}

// AdHocEvent implements docs/domain-model.md's "Ad-hoc Event". It has no
// startAt/endAt of its own — those live on the TimeSlot(s) that reference
// it, per that doc's Time Slot definition.
model AdHocEvent {
  id        String   @id @default(cuid())
  title     String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// TimeSlot implements docs/domain-model.md's "Time Slot": the atomic
// bookable unit, referencing one of six occupant kinds (or none, for
// Slack). Prisma/sqlite has no polymorphic relation support, so the
// occupant is a discriminator (`occupantType`) plus a loose id
// (`occupantId`, not a foreign key) — src/server/time-slots.ts validates
// that `occupantType` is one of the six kinds and, when it isn't "slack",
// that `occupantId` actually exists in the corresponding table.
model TimeSlot {
  id           String   @id @default(cuid())
  startAt      DateTime
  endAt        DateTime
  occupantType String
  occupantId   String?
  // Set when the user confirms, via the daily check-in gate
  // (src/server/check-ins.ts), that this session actually happened. Only
  // ever meaningful for occupantType "trackable-item"/"deadline-task" — a
  // session the gate never asks about (future slot, or a Routine/Fixed
  // Commitment/Ad-hoc Event/Slack occurrence) stays null forever. A "no,
  // didn't happen" answer deletes the Time Slot outright instead of ever
  // writing a "missed" value here.
  confirmedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([startAt, endAt])
}
