// Prisma schema for Progressor. See docs/domain-model.md for the canonical
// concept definitions these models implement, and docs/system-direction.md
// for the layering rule (only src/server/ may import from @prisma/client).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// TrackableItem implements docs/domain-model.md's "Trackable Item" (Book /
// Course). `type` and `status` are plain strings, not Prisma enums, because
// the sqlite connector has no native enum support — validity is enforced in
// src/server/trackable-items.ts instead.
model TrackableItem {
  id             String   @id @default(cuid())
  title          String
  type           String
  priority       Int
  status         String   @default("not-started")
  unitCount      Int
  unitsCompleted Int      @default(0)
  estimatedDays  Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([type, status])
}

// WipLimit implements docs/domain-model.md's "WIP Limit": one configured
// maxInProgress per TrackableItem `type`, enforced independently per type.
model WipLimit {
  type          String @id
  maxInProgress Int
}

// Routine implements docs/domain-model.md's "Routine". `cadence` and
// `timeOfDayPreference` are plain strings for the same reason as
// TrackableItem's `type`/`status` (no sqlite enum support). `anchor`'s
// shape depends on `cadence` (weekday(s) for weekly, day(s)-of-month for
// monthly, unused for daily), so it's stored as a JSON-encoded array of
// integers and validated in src/server/routines.ts rather than as columns.
// `preferredStartTime` ("HH:mm", 24h) is the domain-model doc's
// Time-of-Day Preference "(or an explicit hour range)" case: an optional
// concrete anchor the Scheduler tries before `timeOfDayPreference`'s
// four-bucket window.
model Routine {
  id                  String   @id @default(cuid())
  title               String
  category            String
  cadence             String
  anchor              String?
  timeOfDayPreference String?
  preferredStartTime  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// FixedCommitment and DeadlineTask both implement docs/domain-model.md's
// "Semester Commitment" umbrella — deliberately two separate models, not
// one polymorphic table, because the two kinds are semantically
// incompatible (hard constraint vs. flexible-before-a-deadline) and must
// stay non-interchangeable in code, per that doc's Naming Conventions
// section (the same rule that keeps Routine and Fixed Commitment apart).
// `ignoreSemesterBounds` (default false): when a `Semester` is
// configured, a Fixed Commitment is only placed for weeks inside its
// [start week, start week + weekCount) range unless this is true (e.g.
// a standing meeting with a professor that isn't semester-bound). See
// `Semester` below and src/scheduler/hard-constraints.ts.
model FixedCommitment {
  id                   String   @id @default(cuid())
  title                String
  dayOfWeek            Int
  startTime            String
  endTime              String
  ignoreSemesterBounds Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model DeadlineTask {
  id            String   @id @default(cuid())
  title         String
  dueAt         DateTime
  estimatedDays Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Singleton (fixed id — this is a single-user app, one active semester
// at a time): a configurable start date + week count (default 16) that
// bounds a non-opted-out FixedCommitment's occurrences, and drives the
// Weekly View's "第 N 週" display. Not part of docs/domain-model.md's
// original concept list — added 2026-07-21 for `Semester`-scoped Fixed
// Commitments; see that doc's "Semester Commitment" section for the
// terminology this extends.
model Semester {
  id        String   @id @default("singleton")
  startDate DateTime
  weekCount Int      @default(16)
  updatedAt DateTime @updatedAt
}

// AdHocEvent implements docs/domain-model.md's "Ad-hoc Event". It has no
// startAt/endAt of its own — those live on the TimeSlot(s) that reference
// it, per that doc's Time Slot definition.
model AdHocEvent {
  id        String   @id @default(cuid())
  title     String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// TimeSlot implements docs/domain-model.md's "Time Slot": the atomic
// bookable unit, referencing one of six occupant kinds (or none, for
// Slack). Prisma/sqlite has no polymorphic relation support, so the
// occupant is a discriminator (`occupantType`) plus a loose id
// (`occupantId`, not a foreign key) — src/server/time-slots.ts validates
// that `occupantType` is one of the six kinds and, when it isn't "slack",
// that `occupantId` actually exists in the corresponding table.
model TimeSlot {
  id           String   @id @default(cuid())
  startAt      DateTime
  endAt        DateTime
  occupantType String
  occupantId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([startAt, endAt])
}
